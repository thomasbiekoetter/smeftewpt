Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"tadpoleEquation", "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"V0", "[", "Phi", "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1"}], "]"}], "]"}], ",", "h"}], "]"}], "/.", 
