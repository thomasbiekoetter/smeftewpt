  3.9870464240092154`*^9}},ExpressionUUID->"ec4c97dc-508c-4707-9d77-\
0cc681e09f55"],

Cell[BoxData[
 RowBox[{
  RowBox[{"V0SM", "[", "Phi_", "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"-", "musq"}], " ", 
    RowBox[{
     RowBox[{"ConjugateTranspose", "[", "Phi", "]"}], ".", "Phi"}]}], "+", 
   RowBox[{"lam", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"ConjugateTranspose", "[", "Phi", "]"}], ".", "Phi"}], ")"}], 
     "^", "2"}]}]}]}]], "Input",
 CellChangeTimes->{{3.987046383449168*^9, 3.987046400689015*^9}, {
  3.987046479505679*^9, 3.987046486927732*^9}, {3.987046608173444*^9, 
  3.987046631181532*^9}, {3.987053117796361*^9, 3.987053123570166*^9}},
 CellLabel->"In[52]:=",ExpressionUUID->"3fa4651f-6943-4424-8b42-7a91e0aedb82"],

Cell[BoxData[
 RowBox[{
  RowBox[{"V0SMEFT", "[", "Phi_", "]"}], ":=", 
  RowBox[{
   RowBox[{"-", 
    RowBox[{"(", 
     RowBox[{"CH", "/", 
      RowBox[{"LamUV", "^", "2"}]}], ")"}]}], 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"ConjugateTranspose", "[", "Phi", "]"}], ".", "Phi"}], " ", 
     ")"}], "^", "3"}]}]}]], "Input",
 CellChangeTimes->{{3.987046428861876*^9, 3.9870464588617563`*^9}, {
  3.987046489073298*^9, 3.987046493041842*^9}, {3.987046636584092*^9, 
  3.987046638643491*^9}, {3.987053100746176*^9, 3.987053108369382*^9}},
 CellLabel->"In[49]:=",ExpressionUUID->"52c3c6dc-5195-4456-b796-85a8ab489651"],

Cell[BoxData[
 RowBox[{
  RowBox[{"V0", "[", "Phi_", "]"}], ":=", 
  RowBox[{
   RowBox[{"V0SM", "[", "Phi", "]"}], "+", 
   RowBox[{"V0SMEFT", "[", "Phi", "]"}]}]}]], "Input",
 CellChangeTimes->{{3.987046898048398*^9, 3.987046902552389*^9}, {
  3.9870529818009443`*^9, 3.987053008215049*^9}},
 CellLabel->"In[53]:=",ExpressionUUID->"5255c4ee-6b93-42b5-a56c-0b54e08abda2"],

