Notebook[{

Cell[CellGroupData[{
Cell["SMEFT with only CH", "Chapter",
 CellChangeTimes->{{3.987046348920711*^9, 
  3.987046353130525*^9}},ExpressionUUID->"3bc2e4a9-d8b8-4250-a8ff-\
cc6295867859"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Phi", "=", 
   RowBox[{
    RowBox[{"1", "/", 
     RowBox[{"Sqrt", "[", "2", "]"}]}], 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", "Gpm", "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"h", "+", 
        RowBox[{"I", " ", "G0"}]}], "}"}]}], "}"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Conjugate", "[", "h", "]"}], "^=", "h"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Conjugate", "[", "G0", "]"}], "^=", "G0"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Conjugate", "[", "Gpm", "]"}], "^=", "Gmp"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9870464949274893`*^9, 3.987046520005138*^9}, {
  3.987046560248022*^9, 3.987046582251996*^9}, {3.987046663262944*^9, 
  3.987046741544042*^9}, {3.987046794119334*^9, 3.987046803258643*^9}},
 CellLabel->"In[35]:=",ExpressionUUID->"beb36c0f-f9d9-4803-9caa-aa945151178f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"EWvac", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Gpm", "\[Rule]", "0"}], ",", 
     RowBox[{"Gmp", "\[Rule]", "0"}], ",", 
     RowBox[{"G0", "\[Rule]", "0"}], ",", 
     RowBox[{"h", "\[Rule]", "v"}]}], "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.987046821358437*^9, 3.987046867457898*^9}},
 CellLabel->"In[43]:=",ExpressionUUID->"581fd39f-d395-460a-96fd-1fb17999554a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"onlyh", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Gpm", "\[Rule]", "0"}], ",", 
     RowBox[{"Gmp", "\[Rule]", "0"}], ",", 
     RowBox[{"G0", "\[Rule]", "0"}]}], "}"}]}], ";"}]], "Input",
