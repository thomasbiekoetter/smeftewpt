      RowBox[{"Gamma", "[", 
       RowBox[{
        RowBox[{"d", "/", "2"}], "+", "delta"}], "]"}], 
      RowBox[{"Zeta", "[", 
       RowBox[{
        RowBox[{"2", 
         RowBox[{"(", 
          RowBox[{"alpha", "-", "beta", "-", "delta"}], ")"}]}], "-", "d"}], 
       "]"}]}], ")"}], "/", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Gamma", "[", 
       RowBox[{"1", "/", "2"}], "]"}], 
      RowBox[{"Gamma", "[", "alpha", "]"}], 
      RowBox[{"Gamma", "[", 
